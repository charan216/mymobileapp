{
  "expo": {
    "name": "HomeSpace",
    "slug": "homespace",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#FF6B35"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourname.homespace"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FF6B35"
      },
      "package": "com.yourname.homespace"
    },
    "web": {
      "bundler": "metro"
    },
    "scheme": "homespace",
    "plugins": [
      "expo-asset"
    ]
  }
}
